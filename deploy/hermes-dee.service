[Unit]
Description=Hermes Agent - Dee
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
User=dewoller
Group=dewoller
WorkingDirectory=/tank/services/active_services/hermes
Environment=PATH=/home/dewoller/.local/bin:/home/dewoller/.volta/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/dewoller
Environment=HERMES_HOME=/tank/services/active_services/hermes-dee

ExecStartPre=+/usr/local/bin/sops-decrypt.sh hermes-dee
ExecStartPre=/bin/ln -sf /run/secrets/hermes-dee/.env /tank/services/active_services/hermes-dee/.env
ExecStart=/tank/services/active_services/hermes/.venv/bin/hermes gateway
ExecStopPost=+/bin/rm -rf /run/secrets/hermes-dee

Restart=always
RestartSec=10
StandardOutput=append:/tank/services/active_services/hermes-dee/logs/hermes.log
StandardError=append:/tank/services/active_services/hermes-dee/logs/hermes.error.log

[Install]
WantedBy=multi-user.target
